# EditorConfig — cross-editor consistency.
# https://editorconfig.org/
#
# Mirrors the WordPress coding standards:
#  - PHP uses real tabs (WPCS rule)
#  - JS/JSON/YAML uses 2 spaces (Prettier / Gutenberg default)
#  - Everything else uses tabs

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,yml,yaml,scss,css,md}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
