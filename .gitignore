# Dependencies — restored by `composer install` and `npm ci`.
/vendor/
node_modules/

# Built bundles — produced by `npm run build`, never committed.
/build/

# Packed plugin ZIPs — produced by `npm run pack`.
/releases/

# Translation template — regenerated by `wp i18n make-pot` on every
# `npm run pack`, so the committed copy only ever produced churn (the
# POT-Creation-Date header changes each run). The release ZIP still
# ships a fresh one. The human-authored .po/.mo files stay tracked.
/languages/404-to-301.pot

# Tool caches.
/.phpcs.cache
/.phpunit.result.cache
/coverage/

# `composer.lock` stays gitignored — this is a plugin (a library, not
# an application), so consumers' Composer installs resolve fresh against
# their own constraints. `package-lock.json` *is* committed so CI can
# `npm ci` against deterministic builds and `actions/setup-node` can
# warm its cache.
composer.lock

# Local dev conveniences.
.claude/
.config.json
config.json

# Editor directories and files.
.idea/
.vscode/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local env files.
.env.local
.env.*.local

# Log files.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS noise.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log
