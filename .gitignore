# Dependencies — restored by `composer install` and `npm ci`.
/vendor/
node_modules/

# Built bundles — produced by `npm run build`, never committed.
/build/

# Packed plugin ZIPs — produced by `npm run pack`.
/releases/

# Tool caches.
/.phpcs.cache
/.phpunit.result.cache
/coverage/

# Lockfiles intentionally not committed (matches existing project policy).
package-lock.json
composer.lock

# Local dev conveniences.
.claude/
.config.json
config.json

# Editor directories and files.
.idea/
.vscode/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local env files.
.env.local
.env.*.local

# Log files.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS noise.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log
